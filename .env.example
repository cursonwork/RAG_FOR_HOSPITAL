# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# DashScope (Qwen 多模态 — 图片描述生成)
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.7-plus

# Ollama Embedding
OLLAMA_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL_NAME=bge-m3

# Milvus (Docker)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=hospital_knowledge
EMBEDDING_DIMENSION=1024

# PostgreSQL (Docker) — 用户/会话/消息持久化
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=hospital_rag
PG_USER=postgres
PG_PASSWORD=postgres

# PDF parser: "opendataloader" (需 Java 17+) | "pymupdf"
PDF_PARSER=opendataloader

# 分块参数 — 2000 字符约等于 2-3 个完整英文段落，保证医学语义完整
CHUNK_SIZE=2000
CHUNK_OVERLAP=100

# 检索参数
RETRIEVAL_TOP_K=5

# Hybrid search (客户端 BM25 + Dense RRF 融合)
HYBRID_ENABLED=true
HYBRID_RETRIEVAL_TOP_K=20

# Reranker (FlashRank cross-encoder, CPU-friendly ONNX)
RERANKER_ENABLED=true
RERANKER_MODEL=ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=5

# Query rewriting (4 策略：多轮补全/短问题扩展/长问题回退/直通)
QUERY_REWRITING_ENABLED=true

# Image understanding (PyMuPDF 提取图片 → Qwen 多模态描述)
ENABLE_IMAGE_UNDERSTANDING=true
IMAGE_MAX_SIZE=800
IMAGE_MAX_CONCURRENT=8
IMAGE_MIN_BYTES=5120
